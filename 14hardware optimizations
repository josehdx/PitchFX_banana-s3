[env:esp32-s3-banana-leaf]
platform = https://github.com/pioarduino/platform-espressif32/releases/download/55.03.36/platform-espressif32.zip
board = bpi_leaf_s3
framework = arduino
monitor_speed = 115200

; 1. Maximize Clock Speeds
board_build.f_cpu = 240000000L      ; Ensure CPU is at 240MHz
board_build.f_flash = 80000000L     ; Max flash speed (verify your hardware supports 80MHz)
board_build.flash_mode = qio        ; Quad I/O mode for faster code loading

; Only Control Surface remains in lib_deps
lib_deps = 
	tttapa/Control Surface@^2.1.0

; Update flags to point to the new local lib location
build_flags = 
	-O3
    -ffast-math                     ; Allows the compiler to simplify math (slight precision loss for huge speed gains)
	 

	-D ARDUINO_USB_MODE=0
	-D CORE_DEBUG_LEVEL=0
	-D ARDUINO_USB_CDC_ON_BOOT=1
	-D USB_MANUFACTURER="\"Whammy_S3\""
    -D USB_PRODUCT="\"Whammy_S3\""

	-D CONFIG_ARDUINO_LOOP_STACK_SIZE=16384 ; Increase stack size for complex audio math

	
	-D TOUCH_CS=-1
	-I lib/esp-dsp/modules/fft/include
	-I lib/esp-dsp/modules/common/include
	-I lib/esp-dsp/modules/math/include
    -I lib/esp-dsp/modules/wind/include